# Augur Environment Variables
# Copy to .env and fill in your values

# === API Authentication (optional) ===
# When set, all /api/* endpoints require Authorization: Bearer <token> header.
# Leave empty or unset for open access (no authentication required).
AUGUR_API_TOKEN=

# === Telegram Bot ===
TELEGRAM_TOKEN=your_telegram_bot_token

# === Slack Bot ===
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_APP_TOKEN=xapp-your-slack-app-token

# === WeChat 个人微信 (GeWeChat - 推荐) ===
GEWECHAT_BASE_URL=http://127.0.0.1:2531/v2/api
GEWECHAT_TOKEN=your_gewechat_token
GEWECHAT_APP_ID=

# === WeChat 企业微信 (WeCom) ===
WECHAT_CORP_ID=your_corp_id
WECHAT_CORP_SECRET=your_corp_secret
WECHAT_AGENT_ID=your_agent_id
WECHAT_TOKEN=your_callback_token
WECHAT_AES_KEY=your_encoding_aes_key
WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# === Lark/飞书 ===
LARK_APP_ID=your_app_id
LARK_APP_SECRET=your_app_secret
LARK_VERIFICATION_TOKEN=your_verification_token
LARK_ENCRYPT_KEY=your_encrypt_key
LARK_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
